# Copy this file to .env and fill in your values

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:27b

# Ngrok TCP tunnel pointing to your MySQL instance
# e.g. from `ngrok tcp 3306` you get:  tcp://2.tcp.ngrok.io:19302
NGROK_DB_HOST=2.tcp.ngrok.io
NGROK_DB_PORT=19302

# MySQL credentials
DB_NAME=items_db
DB_USER=root
DB_PASSWORD=your_password_here

# Path to the schema file (relative to project root)
SCHEMA_PATH=items_schema.sql
